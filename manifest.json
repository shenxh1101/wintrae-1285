{
  "manifest_version": 3,
  "name": "价格猎手 - 网购价格观察助手",
  "version": "1.0.0",
  "description": "管理商品价格观察与购买决策：一键加入观察、目标价提醒、价格波动追踪、多商品比较",
  "permissions": ["storage", "notifications", "alarms", "activeTab"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "pages/settings/settings.html"
}
